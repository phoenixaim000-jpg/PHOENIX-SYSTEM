# --- フィアナ流ロジックの計算セクション ---
def calculate_fiana_signals(data):
    # 1. 9SMA & 20SMA の計算
    data['9SMA'] = data['Close'].rolling(window=9).mean()
    data['20SMA'] = data['Close'].rolling(window=20).mean()
    
    # 2. トレンド判断 (パーフェクトオーダー)
    data['Trend'] = np.where(data['9SMA'] > data['20SMA'], "上昇トレンド", "下降トレンド")
    
    # 3. フィボナッチ（直近高値・安値からの計算）
    recent_high = data['High'].max()
    recent_low = data['Low'].min()
    diff = recent_high - recent_low
    data['Fib_61.8'] = recent_high - diff * 0.618
    data['Fib_50.0'] = recent_high - diff * 0.5
    
    return data

